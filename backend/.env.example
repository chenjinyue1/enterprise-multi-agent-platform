# ============================================================
# 环境变量配置模板
# 
# 使用说明：
# 1. 复制本文件为 .env:  cp .env.example .env
# 2. 编辑 .env 填入真实值
# 3. .env 文件已加入 .gitignore，不会提交到Git
#
# 为什么用环境变量？
# - 安全：密钥不写在代码里，防止泄露
# - 灵活：开发/测试/生产用不同配置，不改代码
# - 标准：12-Factor App 推荐做法
# ============================================================

# --- 应用配置 ---
APP_NAME=Enterprise Multi-Agent Platform
APP_VERSION=0.1.0
DEBUG=true
ENV=development

# --- API配置 ---
# 后端服务地址
HOST=0.0.0.0
PORT=8000

# --- 安全 ---
# JWT密钥：生产环境必须用强随机字符串！
# 生成命令: openssl rand -hex 32
SECRET_KEY=your-super-secret-key-change-this-in-production
# JWT令牌过期时间（分钟）
ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- OpenAI / LLM ---
# 你的OpenAI API Key（或其他兼容OpenAI的API）
OPENAI_API_KEY=sk-your-openai-api-key
# 模型选择：开发用gpt-4o-mini（便宜），生产用gpt-4o
OPENAI_MODEL=gpt-4o-mini
# API基础地址（如果用代理或国产模型）
# OPENAI_BASE_URL=https://api.openai.com/v1

# --- MySQL ---
# 格式: mysql+aiomysql://用户名:密码@主机:端口/数据库名
MYSQL_URL=mysql+aiomysql://root:password@localhost:3306/multi_agent_db
MYSQL_POOL_SIZE=10
MYSQL_MAX_OVERFLOW=20

# --- Redis ---
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# --- ChromaDB ---
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION_NAME=report_templates

# --- MCP ---
# MCP服务端口（如果MCP Server独立部署）
MCP_DB_SERVER_PORT=8001
MCP_PYTHON_SERVER_PORT=8002

# --- LangSmith（可选，用于观测）---
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=your-langsmith-key
# LANGCHAIN_PROJECT=multi-agent-platform
